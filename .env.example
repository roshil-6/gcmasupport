# Copy to .env.local and set values. Never commit .env.local.
ADMIN_PASSWORD=

# Railway / Postgres (Vercel production): full public connection string as DATABASE_URL
# When unset, submissions are stored under ./data/*.json (local dev only).
DATABASE_URL=

# Production / Vercel: your public site URL (no trailing slash). Used for canonical URLs, OG tags, JSON-LD.
# Example: https://gcma.vercel.app or https://yourdomain.com
NEXT_PUBLIC_SITE_URL=
